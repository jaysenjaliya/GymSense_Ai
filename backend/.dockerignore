# Keep the image lean and secrets out of it.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Never bake secrets into the image — env is injected at runtime.
.env
.env.*
!.env.example

# Tests aren't needed at runtime.
tests/

# Docs / misc
*.md

# NOTE: app/models/*.pt IS intentionally included (needed for inference).
