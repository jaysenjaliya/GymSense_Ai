# Backend configuration. Copy to .env and fill in values.

# MongoDB Atlas connection string + database name
MONGODB_URI=
MONGODB_DB_NAME=gymsense

# JWT auth (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ML model artifact (PyTorch .pt) — drop the file in app/models/
ML_MODEL_PATH=app/models/recgym_classifier.pt

# LLM (Anthropic)
LLM_API_KEY=
LLM_MODEL=claude-opus-4-8

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173
