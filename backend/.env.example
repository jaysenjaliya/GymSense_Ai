# Backend configuration. Copy to .env and fill in values.

# MongoDB connection string + database name
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=gymsense

# JWT auth (generate a secret with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-please-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ML model artifact (PyTorch state_dict .pt) — drop the file in app/models/
ML_MODEL_PATH=app/models/model_weights.pt

# LLM (Anthropic)
LLM_API_KEY=
LLM_MODEL=claude-opus-4-8

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173
